# VoltDesk Environment Configuration

# Backend API
PORT=8081
DATABASE_URL=postgres://postgres:postgres@localhost:5433/voltdesk?sslmode=disable
GEMINI_API_KEY=your_gemini_api_key_here
JWT_SECRET=super-secret-default-key-for-dev

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=voltdesk-archive
